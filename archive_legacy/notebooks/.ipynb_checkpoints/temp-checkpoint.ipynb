   "source": [
    "import time\n",
    "import torch\n",
    "tic = time.time()\n",
    "a = torch.rand(1000)\n",
    "b = torch,rand(1000)\n",
    "c = a @ b\n",
    "tic = time.time()\n",
    "print(\"1:{1000*(tic-toc)} ms\")\n",
    "tic = time.time()\n",
    "for i in range(100000)\n",
    "    c += a[i]*[b[i]\n",
    "toc = time.time()\n",
    "print(\"2:{1000*(tic-toc)} ms\")"
   ]
  }
